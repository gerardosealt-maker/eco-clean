# Contraseña para entrar a la app. Cámbiala por una temporal al publicarla.
APP_PASSWORD="EcoClean2026*"

# Frase larga para firmar la sesión. Puede ser cualquier frase larga y única.
APP_SESSION_SECRET="cambia-esta-frase-por-una-frase-larga-y-unica-eco-clean"

# Supabase. Puedes pegar el Project URL o el API URL que termina en /rest/v1/.
SUPABASE_URL=""

# Supabase Secret Key. NO la subas a GitHub; solo pégala en Vercel > Environment Variables.
SUPABASE_SECRET_KEY=""

# Identificador del estado principal de la app.
APP_STATE_ID="eco-clean"
